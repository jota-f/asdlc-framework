# A-SDLC Framework - Variáveis de Ambiente
# Copie este arquivo para .env e configure suas chaves

# ============================================
# MOTOR DE EXECUÇÃO (OBRIGATÓRIO)
# ============================================
# antigravity = Usa o IDE como cérebro. Sem custo de API. (PADRÃO)
# external    = Usa API OpenAI/OpenRouter para execução autônoma via CLI/MCP.
ASDLC_ENGINE=antigravity

# ============================================
# PROVEDOR DE LLM (só usado quando ASDLC_ENGINE=external)
# ============================================
# Preferência: OPENROUTER_API_KEY > OPENAI_API_KEY
OPENROUTER_API_KEY=sua_chave_openrouter_aqui
OPENAI_API_KEY=sua_chave_openai_aqui

# Modelo padrão (quando não especificado por agente)
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3

# ============================================
# MODELOS POR AGENTE (opcional)
# ============================================
# Se não definido, usa OPENAI_MODEL como fallback
# MODEL_CODE=gpt-4
# MODEL_ARCH=gpt-4
# MODEL_TEST=gpt-4
# MODEL_REQ=gpt-4
# MODEL_REVIEW=gpt-4.1-mini

# ============================================
# CONFIGURAÇÕES DO FRAMEWORK
# ============================================
ASDLC_LOG_LEVEL=INFO
ASDLC_CACHE_ENABLED=true
DEBUG_MODE=false
VERBOSE_OUTPUT=false
