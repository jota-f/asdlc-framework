# A-SDLC Framework - Variáveis de Ambiente
# Copie este arquivo para .env e configure suas chaves

# ============================================
# MOTOR DE EXECUÇÃO (OBRIGATÓRIO)
# ============================================
# antigravity = Usa o Antigravity (IDE) como cérebro. Sem custo de API. (PADRÃO)
# external    = Usa a API OpenAI para execução autônoma via CLI/MCP.
ASDLC_ENGINE=antigravity

# OpenAI API Configuration (só usado quando ASDLC_ENGINE=external)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# Framework Configuration
ASDLC_LOG_LEVEL=INFO
ASDLC_CACHE_ENABLED=true
ASDLC_TEMP_DIR=.asdlc/temp

# Project Defaults
DEFAULT_PROJECT_TYPE=web_frontend
DEFAULT_LLM_PROVIDER=openai

# Development Settings
DEBUG_MODE=false
VERBOSE_OUTPUT=false 